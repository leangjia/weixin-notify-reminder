# Server Configuration
TZ=Asia/Shanghai
PORT=3000

# WeChat Work Bot Configuration
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send
WECHAT_WEBHOOK_KEY=your_actual_webhook_key_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=xxx@qq.com
SMTP_PASS=your_smtp_password

# Database Configuration
DB_PATH=./data/data.db

# Excel File Path (for import)
EXCEL_PATH=/mnt/ROHS
# Windows: EXCEL_PATH=\\\\10.85.10.10\\ROHS

# Reminder Settings
REMINDER_DAYS_THRESHOLD=15
REPORT_VALID_DAYS=364
